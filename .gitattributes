# List generated files
# - prevents GitHub from showing deltas during code review
# - informs the rules_lint formatter not to apply formatting rules

# Vendored / tool-managed files kept verbatim (not reformatted by rules_lint).
*.axl                     linguist-generated=true
.vscode/*.json            linguist-generated=true
.devcontainer/*.json      linguist-generated=true
tools/scripts/*           linguist-generated=true
tools/remote/setup.sh     linguist-generated=true
