# List generated files
# - prevents GitHub from showing deltas during code review
# - informs the rules_lint formatter not to apply formatting rules
# Template-owned config and tooling: vendored, hand-maintained, and (for several)
# scaffold-templated so prettier/shfmt cannot parse the source. Exclude them from
# //tools/format / //:tidy so a fresh repo is tidy out of the box and stays that
# way across formatter version bumps (rules-lint-ignored is honored by
# aspect_rules_lint's formatter).
*.axl                  rules-lint-ignored=true
.vscode/*.json         rules-lint-ignored=true
.devcontainer/*.json   rules-lint-ignored=true
githooks/*             rules-lint-ignored=true
tools/scripts/*        rules-lint-ignored=true
tools/tools.lock.json  rules-lint-ignored=true
tools/*.sh             rules-lint-ignored=true
tools/**/*.sh          rules-lint-ignored=true
